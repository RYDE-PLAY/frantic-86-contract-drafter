{
  "schema": "runx.contract_drafter.input.v1",
  "template": {
    "template_id": "public-services-review-v1",
    "title": "Services Agreement Review Draft",
    "source_ref": "https://raw.githubusercontent.com/RYDE-PLAY/frantic-86-contract-drafter/6d98cea1893b18957da25ae5202958f5975f2c56/public/template.json",
    "data_classification": "synthetic_nonbinding_demo",
    "required_party_roles": [
      "provider",
      "customer"
    ],
    "required_terms": [
      "effective_date",
      "services",
      "fees",
      "payment_terms",
      "liability_cap",
      "governing_law",
      "confidentiality_period"
    ],
    "baseline": {
      "payment_terms": "Net 30",
      "liability_cap": "Fees paid in the prior 12 months",
      "governing_law": "California",
      "confidentiality_period": "3 years"
    },
    "term_clauses": {
      "payment_terms": "fees",
      "liability_cap": "liability",
      "governing_law": "governing-law",
      "confidentiality_period": "confidentiality"
    },
    "clauses": [
      {
        "id": "parties",
        "title": "Parties and Effective Date",
        "body_template": "{{parties.provider.legal_name}} and {{parties.customer.legal_name}} enter this agreement effective {{terms.effective_date}}."
      },
      {
        "id": "services",
        "title": "Services",
        "body_template": "{{parties.provider.legal_name}} will provide {{terms.services}}."
      },
      {
        "id": "fees",
        "title": "Fees and Payment",
        "body_template": "{{parties.customer.legal_name}} will pay {{terms.fees}} under {{terms.payment_terms}} payment terms."
      },
      {
        "id": "liability",
        "title": "Limitation of Liability",
        "body_template": "The aggregate liability cap is {{terms.liability_cap}}."
      },
      {
        "id": "confidentiality",
        "title": "Confidentiality",
        "body_template": "Confidentiality obligations survive for {{terms.confidentiality_period}}."
      },
      {
        "id": "governing-law",
        "title": "Governing Law",
        "body_template": "The agreement is governed by {{terms.governing_law}}."
      }
    ]
  },
  "parties": {
    "provider": {
      "legal_name": "Northstar Example Services LLC",
      "role": "provider",
      "data_classification": "synthetic"
    },
    "customer": {
      "legal_name": "Harbor Example Studio Inc.",
      "role": "customer",
      "data_classification": "synthetic"
    }
  },
  "terms": {
    "effective_date": "2026-07-15",
    "services": "Monthly release engineering review and incident-readiness support",
    "fees": "USD 8,000 per month",
    "payment_terms": "Net 45",
    "liability_cap": "USD 80,000 aggregate",
    "governing_law": "Delaware",
    "confidentiality_period": "2 years",
    "send": {
      "objective": "Prepare this public nonbinding review draft for a separate governed send-as planning run.",
      "principal": "github:RYDE-PLAY",
      "audience": {
        "type": "repository_review",
        "ref": "RYDE-PLAY/frantic-86-contract-drafter"
      },
      "consent_basis": "The repository owner requested public review of this synthetic nonbinding demonstration draft.",
      "operator_context": "Draft only; human approval and provider preflight remain required. No provider delivery is authorized by contract-drafter.",
      "subject_or_title": "Review the public services agreement demonstration draft"
    }
  }
}
